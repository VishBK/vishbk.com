RewriteEngine On

# 1. Redirect standard .html paths to their extensionless versions
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.html
RewriteRule ^/?(.*)\.html$ https://%{HTTP_HOST}/$1 [L,R=301]

# 2. Internally serve the .html file when the clean URL is requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
